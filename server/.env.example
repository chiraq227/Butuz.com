# Server Configuration
PORT=5001
# IMPORTANT for production / beta hosting:
# Generate strong secret (run in terminal):   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# NEVER use weak/default values. Minimum 32 chars, preferably 64+ random hex.
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=7d

# REQUIRED for production deploy (single origin or separate frontend):
# Set to your public frontend URL, e.g. https://butuz-beta.onrender.com   or https://yourapp.vercel.app
# Include protocol, no trailing slash. Used for CORS.
CLIENT_URL=

# Admin access (comma-separated, case-insensitive usernames that can use /api/casino/admin/*)
# The account(s) listed here have god-mode over all user casino balances, bans, etc.
# Use a strong unique password for these accounts and never share the credentials.
# For beta: change this to your tester admin username(s) and use very strong password.
ADMIN_USERNAMES=butuz

# Database (SQLite file will be created in server/ directory)
# On most free hostings the FS may be ephemeral - use seed/reset or external volume.
DB_PATH=./butuz.db

# For beta testing with narrow circle it is often easier and more reliable to run
# on your own machine + free tunnel (see full instructions at end of README or BETA_DEPLOY.md)
