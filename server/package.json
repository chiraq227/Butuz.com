{
  "name": "butuz-server",
  "version": "1.0.0",
  "description": "Backend for Butuz.com social network MVP",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "seed": "node src/seed.js",
